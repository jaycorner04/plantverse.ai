# Copy to backend/.env for local backend testing.
# On a hosted server, add these as platform environment variables instead.
PORT=8787
ALLOWED_ORIGINS=*
MAX_BODY_BYTES=12000000

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

GROQ_API_KEY=
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-4-maverick:free

PLANTNET_API_KEY=
PLANT_ID_API_KEY=
PERENUAL_API_KEY=

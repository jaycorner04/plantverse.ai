# Copy this file to `.env` and fill in your own local keys.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Use this for public/friend APKs so provider keys stay on your backend server.
BACKEND_BASE_URL=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional backup/secondary providers. Create your own free/limited keys.
# Groq vision fallback: https://console.groq.com/
GROQ_API_KEY=
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# OpenRouter vision fallback: https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-4-maverick:free

# Pl@ntNet photo ID: https://my.plantnet.org/
PLANTNET_API_KEY=

# Plant.id / Kindwise photo ID: https://www.kindwise.com/plant-id
PLANT_ID_API_KEY=

# Perenual plant data enrichment: https://www.perenual.com/docs/api
PERENUAL_API_KEY=

# Copy this file to `.env` and fill in your own local keys.
SUPABASE_URL=
SUPABASE_ANON_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# Optional backup/secondary providers. Create your own free/limited keys.
# Groq vision fallback: https://console.groq.com/
GROQ_API_KEY=
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Pl@ntNet photo ID: https://my.plantnet.org/
PLANTNET_API_KEY=

# Plant.id / Kindwise photo ID: https://www.kindwise.com/plant-id
PLANT_ID_API_KEY=

# Perenual plant data enrichment: https://www.perenual.com/docs/api
PERENUAL_API_KEY=
